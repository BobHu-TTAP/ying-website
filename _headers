# Cloudflare Pages — response headers.
# Conservative, safe defaults (no strict CSP yet so Google Fonts + inline styles work).
# Tighten with a Content-Security-Policy before production launch.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Long-cache fingerprint-free static assets (safe: they change rarely; purge on deploy).
/assets/*
  Cache-Control: public, max-age=86400
