# Cloudflare Pages — response headers.
# Conservative, safe defaults (no strict CSP yet so Google Fonts + inline styles work).
# Tighten with a Content-Security-Policy before production launch.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Assets are not content-hashed and the site is iterating, so revalidate every load
# (cheap conditional GETs; updates show immediately). Add ?v=N to bust hard-cached copies.
/assets/*
  Cache-Control: public, max-age=0, must-revalidate
